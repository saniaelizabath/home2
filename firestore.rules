rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /admins/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /teachers/{docId} {
      allow read: if true;
      allow write: if true;
    }

    match /students/{uid} {
      allow read:  if true;
      allow write: if true;
    }

    match /announcements/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /courses/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /classes/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /scheduled_classes/{docId} {
      allow read: if true;
      allow write: if true;
    }

    match /assignments/{docId} {
      allow read: if true;
      allow write: if true;
    }

    match /submissions/{docId} {
      allow read: if true;
      allow write: if true;
    }

    match /tests/{docId} {
      allow read: if true;
      allow write: if true;
    }

    match /notes/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Teacher attendance — open read/write (admin-only UI, no sensitive data)
    match /teacher_attendance/{teacherId} {
      allow read:  if true;
      allow write: if true;
    }

    // Student attendance — teacher writes, student reads their own
    match /student_attendance/{studentId} {
      allow read:  if true;
      allow write: if true;
    }
  }
}