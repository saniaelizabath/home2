rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /admins/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /teachers/{docId} {
      allow read: if true;
      allow write: if true;
    }

    match /students/{uid} {
      allow read:  if true;
      allow write: if true;
    }

    match /announcements/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /courses/{docId} {
      allow read: if true;
      allow write: if true;
    }

    match /classes/{docId} {
      allow read: if true;
      allow write: if true;
    }

    match /scheduled_classes/{docId} {
      allow read: if true;
      allow write: if true;
    }

    match /assignments/{docId} {
      allow read: if true;
      allow write: if true;
    }

    match /submissions/{docId} {
      allow read: if true;
      allow write: if true;
    }

    match /tests/{docId} {
      allow read: if true;
      allow write: if true;
    }

    match /notes/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Chat conversations — open to all authenticated users (teachers use Firestore-only auth)
    match /chats/{chatId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if true;
        allow create: if true;
        allow update: if true;
        allow delete: if true;
      }
    }

    // Legacy top-level messages collection
    match /messages/{docId} {
      allow read: if true;
      allow write: if true;
    }

    match /teacher_attendance/{teacherId} {
      allow read:  if true;
      allow write: if true;
    }

    match /student_attendance/{studentId} {
      allow read:  if true;
      allow write: if true;
    }

    match /tasks/{taskId} {
      allow read: if true;
      allow write: if true;
    }
  }
}